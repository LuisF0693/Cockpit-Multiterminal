{
  "name": "meu-cockpit",
  "version": "0.1.0",
  "private": true,
  "description": "Central de controle multiagente — orquestração de CLIs de IA com sessão master, lifecycle e persistência total",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "node-pty", "esbuild"]
  },
  "scripts": {
    "dev": "turbo run dev --filter=@cockpit/desktop",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "dist": "pnpm --filter @cockpit/desktop dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  }
}
